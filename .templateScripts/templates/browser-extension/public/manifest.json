{
  "manifest_version": 3,
  "name": "My Vite Browser Extension",
  "version": "1.0.0",
  "description": "A browser extension built with Vite and Vue 3",
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "src/extension/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/extension/content-script.js"]
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ]
}